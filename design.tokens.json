{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Design system for lightweight KelbyOne/Grid microsites, submission forms, and event landing pages. Dark, photographic, premium, direct-response, and optimized for fast single-page builds.",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.039,
          0.039,
          0.039
        ],
        "hex": "#0a0a0a"
      }
    },
    "surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.086,
          0.086,
          0.086
        ],
        "hex": "#161616"
      }
    },
    "surface-raised": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.118,
          0.118,
          0.118
        ],
        "hex": "#1e1e1e"
      }
    },
    "surface-hover": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.145,
          0.145,
          0.145
        ],
        "hex": "#252525"
      }
    },
    "border": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.165,
          0.165,
          0.165
        ],
        "hex": "#2a2a2a"
      }
    },
    "text-primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.961,
          0.961,
          0.961
        ],
        "hex": "#f5f5f5"
      }
    },
    "text-secondary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.627,
          0.627,
          0.627
        ],
        "hex": "#a0a0a0"
      }
    },
    "text-muted": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.4,
          0.4,
          0.4
        ],
        "hex": "#666666"
      }
    },
    "grid-gold": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.961,
          0.651,
          0.137
        ],
        "hex": "#f5a623"
      }
    },
    "edit-blue": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.31,
          0.765,
          0.969
        ],
        "hex": "#4fc3f7"
      }
    },
    "edit-blue-strong": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.161,
          0.714,
          0.965
        ],
        "hex": "#29b6f6"
      }
    },
    "summit-gold": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.839,
          0.639,
          0.29
        ],
        "hex": "#d6a34a"
      }
    },
    "success": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.18,
          0.8,
          0.443
        ],
        "hex": "#2ecc71"
      }
    },
    "error": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.906,
          0.298,
          0.235
        ],
        "hex": "#e74c3c"
      }
    },
    "youtube-red": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          0,
          0
        ],
        "hex": "#ff0000"
      }
    },
    "facebook-blue": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.094,
          0.467,
          0.949
        ],
        "hex": "#1877f2"
      }
    },
    "black": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0,
          0,
          0
        ],
        "hex": "#000000"
      }
    },
    "white": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          1,
          1
        ],
        "hex": "#ffffff"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xs": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 32,
        "unit": "px"
      }
    },
    "xxl": {
      "$value": {
        "value": 48,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "sm": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 12,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "pill": {
      "$value": {
        "value": 999,
        "unit": "px"
      }
    }
  },
  "typography": {
    "h1-hero": {
      "$type": "typography",
      "$value": {
        "fontFamily": "-apple-system, BlinkMacSystemFont, Segoe UI, Roboto, sans-serif",
        "fontSize": {
          "value": 4,
          "unit": "rem"
        },
        "fontWeight": 900,
        "letterSpacing": {
          "value": -0.03,
          "unit": "em"
        },
        "lineHeight": 1
      }
    },
    "h2-section": {
      "$type": "typography",
      "$value": {
        "fontFamily": "-apple-system, BlinkMacSystemFont, Segoe UI, Roboto, sans-serif",
        "fontSize": {
          "value": 1.5,
          "unit": "rem"
        },
        "fontWeight": 800,
        "letterSpacing": {
          "value": -0.02,
          "unit": "em"
        },
        "lineHeight": 1.15
      }
    },
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "-apple-system, BlinkMacSystemFont, Segoe UI, Roboto, sans-serif",
        "fontSize": {
          "value": 1,
          "unit": "rem"
        },
        "fontWeight": 400,
        "lineHeight": 1.6
      }
    },
    "label-caps": {
      "$type": "typography",
      "$value": {
        "fontFamily": "-apple-system, BlinkMacSystemFont, Segoe UI, Roboto, sans-serif",
        "fontSize": {
          "value": 0.72,
          "unit": "rem"
        },
        "fontWeight": 800,
        "letterSpacing": {
          "value": 0.18,
          "unit": "em"
        },
        "lineHeight": 1.2
      }
    }
  }
}
